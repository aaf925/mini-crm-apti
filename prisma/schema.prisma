generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VendorStatus {
  IDENTIFICADO
  PRIMERA_REUNION
  DEMO_REALIZADA
  ESPERANDO_PRESUPUESTO
  PRESUPUESTO_RECIBIDO
  NEGOCIANDO
  SELECCIONADO
  DESCARTADO
}

model ErpVendor {
  id                    String       @id @default(uuid())
  companyName           String
  softwareProposed      String
  contactName           String
  email                 String
  phone                 String
  status                VendorStatus @default(IDENTIFICADO)
  estimatedCost         Float?
  estimatedMonths       Float?
  hostingType           String?
  internalOwner         String
  notes                 String?      @db.Text
  
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}
